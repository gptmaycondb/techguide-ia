        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0096ff"
      },
      "package": "com.techguide.ia",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "a9d37ee2-24cc-456f-a558-49c21c31da60"
      }
    },
    "owner": "maycondb"
  }
